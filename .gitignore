# ───────────────────────────────────────────────
# Joule — .gitignore
# PUBLIC REPO. 시크릿 위생 최우선: 키·토큰·상태 디렉토리는 절대 커밋 금지.
# ───────────────────────────────────────────────

# --- Secrets (절대 커밋 금지) ---
.env
.env.*
!.env.example
*.key
*.pem
secrets.json
credentials.json

# --- NemoClaw / Hermes / OpenClaw 토큰·상태 디렉토리 ---
.nemoclaw/
.hermes/
.openclaw/
.omc/
*.session
*.token

# --- superpowers brainstorming 비주얼 컴패니언 (브라우저 mockup 세션) ---
.superpowers/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
.pnpm-store/

# --- 빌드 산출물 ---
dist/
build/
out/
.next/
.cache/
*.tsbuildinfo

# --- 로그·임시 ---
*.log
logs/
tmp/
.tmp/

# --- SQLite DB (런타임 생성 — 커밋 금지) ---
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# --- 데모 산출물 (Hermes 주간 리포트 dry-run preview) ---
weekly-report-preview.html

# --- 데모 영상·오디오·자막 (YouTube 호스팅, repo 에는 안 들어감) ---
# demo-final.mp4 가 113 MB 라 GitHub 100 MB 제한 초과 — 영상은 YouTube 만.
*.mp4
*.mp3
*.srt
*.wav
*.mov
*.avi
*.mkv

# --- OS / IDE ---
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
