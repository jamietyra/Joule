# Joule — 환경 변수 예시
# 사용법: 이 파일을 복사해 `.env` 로 만들고 실제 값을 채운다.
#   PowerShell:  Copy-Item .env.example .env
# .env 는 .gitignore 로 제외됨 — 절대 커밋 금지.

# --- Crusoe Managed Inference ---
# Crusoe API 키 (필수)
CRUSOE_API_KEY=

# Crusoe 엔드포인트 (기본값)
CRUSOE_BASE_URL=https://api.inference.crusoecloud.com/v1

# --- Joule core ---
# SQLite DB 파일 경로 (기본값)
JOULE_DB_PATH=./joule.db

# Joule Hono server 포트 (기본값)
JOULE_PORT=3001

# --- Hermes SMTP (Gmail) ---
# Gmail 발신자 주소 (필수, 주간 리포트 발송용)
GMAIL_USER=

# Gmail App Password (필수, 2FA 활성화 후 발급)
GMAIL_APP_PASSWORD=
