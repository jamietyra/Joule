# Joule — 환경 변수 예시
# 사용법: 이 파일을 복사해 `.env` 로 만들고 실제 값을 채운다.
#   PowerShell:  Copy-Item .env.example .env
# .env 는 .gitignore 로 제외됨 — 절대 커밋 금지.

# Crusoe Managed Inference API 키 (필수)
CRUSOE_API_KEY=

# Crusoe Managed Inference 엔드포인트 (기본값, 비밀 아님 — 필요 시 수정)
CRUSOE_BASE_URL=https://api.inference.crusoecloud.com/v1
