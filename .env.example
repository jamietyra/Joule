# Joule — environment variable examples
# Usage: copy this file to `.env` and fill in real values.
#   PowerShell:  Copy-Item .env.example .env
# .env is gitignored — never commit it.

# --- Crusoe Managed Inference ---
# Crusoe Managed Inference API key (required)
CRUSOE_API_KEY=

# Crusoe endpoint (default)
CRUSOE_BASE_URL=https://api.inference.crusoecloud.com/v1

# --- Joule core ---
# SQLite DB file path (default)
JOULE_DB_PATH=./joule.db

# Joule Hono server port (default)
JOULE_PORT=3001

# --- Hermes SMTP (Gmail) ---
# Gmail sender address (required, for weekly report delivery)
GMAIL_USER=

# Gmail App Password (required, generated after enabling 2FA)
GMAIL_APP_PASSWORD=
